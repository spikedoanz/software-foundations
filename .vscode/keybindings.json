[
    {
        "key": "ctrl+alt+left",
        "command": "-cursorWordPartLeft",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+shift+alt+right",
        "command": "-cursorWordPartRightSelect",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+alt+right",
        "command": "-cursorWordPartRight",
        "when": "textInputFocus"
    },
    {
        "key": "ctrl+alt+e",
        "command": "extension.coq.interpretToEnd",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+end",
        "command": "-extension.coq.interpretToEnd",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+e",
        "command": "extension.coq.interpretToEnd",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+end",
        "command": "-extension.coq.interpretToEnd",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+l",
        "command": "extension.coq.interpretToPoint",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+right",
        "command": "-extension.coq.interpretToPoint",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+l",
        "command": "extension.coq.interpretToPoint",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+right",
        "command": "-extension.coq.interpretToPoint",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+p",
        "command": "extension.coq.stepBackward",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+up",
        "command": "-extension.coq.stepBackward",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+up",
        "command": "-extension.coq.stepBackward",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+n",
        "command": "extension.coq.stepForward",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+down",
        "command": "-extension.coq.stepForward",
        "when": "editorTextFocus && editorLangId == 'coq'"
    },
    {
        "key": "ctrl+alt+n",
        "command": "extension.coq.stepForward",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+down",
        "command": "-extension.coq.stepForward",
        "when": "resourceScheme == 'coq-view'"
    },
    {
        "key": "ctrl+alt+u",
        "command": "workbench.action.output.toggleOutput",
        "when": "workbench.panel.output.active"
    }
]
